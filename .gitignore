# Godot 4+ specific ignores
.godot/

# Imported assets cache (regenerated on import)
*.import

# Android build template (auto-generated by Godot, don't version)
/android/

# Export artifacts
*.apk
*.aab

# Signing keys & credentials — never commit these
*.keystore
*.jks
export_credentials.cfg

# Native GDExtension build deps + outputs (regenerated by native/build.sh)
/native/godot-cpp/
/native/stockfish/
/native/android-ndk-*/
/native/.scons/
native/**/*.os
/native/.sconsign.dblite
/addons/stockfish/bin/*.so
/addons/stockfish/bin/*.dll
/addons/stockfish/bin/*.dylib
# Generated post-build (references the libs above); the template lives in native/
/addons/stockfish/stockfish.gdextension

# Claude local only files
.claude/