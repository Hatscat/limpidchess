#!/usr/bin/env python
# Builds the Stockfish GDExtension: the godot-cpp binding (src/) + Stockfish 11
# (stockfish/src, minus main.cpp) compiled into one shared library.
#
# Run via native/build.sh, which sets up godot-cpp/ and stockfish/ next to this
# file and invokes, e.g.:
#   scons platform=android arch=arm64 target=template_release
import os

env = SConscript("godot-cpp/SConstruct")

# Stockfish 11 sources: all of src/*.cpp except main.cpp, plus syzygy/.
sf_sources = [f for f in Glob("stockfish/src/*.cpp")
              if os.path.basename(str(f)) != "main.cpp"]
sf_sources += Glob("stockfish/src/syzygy/*.cpp")

env.Append(CPPPATH=["src/", "stockfish/src/", "stockfish/src/syzygy/"])
# Stockfish 11 = classical eval (no NNUE net). arm64-friendly flags.
env.Append(CPPDEFINES=["IS_64BIT", "USE_PREFETCH", "NDEBUG"])

# Stockfish 11 is a C++11 codebase (its Makefile uses -std=c++11) and defines its
# own clamp(); godot-cpp builds at C++17 where std::clamp exists → ambiguity.
# Compile the Stockfish sources at their native standard; the binding stays C++17.
# The two only meet through std::string/std::vector, which are ABI-stable across
# standards under one libc++, so mixing is safe.
sf_env = env.Clone()
sf_env["CXXFLAGS"] = [f for f in sf_env["CXXFLAGS"] if not str(f).startswith("-std=")]
sf_env.Append(CXXFLAGS=["-std=c++11"])

objects = [env.SharedObject(s) for s in Glob("src/*.cpp")]
objects += [sf_env.SharedObject(s) for s in sf_sources]

out = "../addons/stockfish/bin/libstockfish_gd{}{}".format(env["suffix"], env["SHLIBSUFFIX"])
library = env.SharedLibrary(out, source=objects)

Default(library)
